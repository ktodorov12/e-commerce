# Shopify Storefront API — copy this file to frontend/.env.local
# (Next.js loads env files from the frontend/ app directory).
#
# Leave everything empty to develop against Shopify's public mock store:
#   https://mock.shop/api  (no credentials required)
#
# When the real store exists, fill both values below — same interface,
# zero code changes (see shopify/src/config.ts).

# e.g. exclusive-wear.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API access token (Headless/Hydrogen channel → Storefront API)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Advanced (optional): full endpoint override. Takes precedence over the two
# values above. Used for pointing at a fixture server in offline e2e runs.
SHOPIFY_STOREFRONT_ENDPOINT=
