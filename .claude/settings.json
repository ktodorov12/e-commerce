{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm test)",
      "Bash(pnpm test:unit)",
      "Bash(pnpm test:e2e)",
      "Bash(pnpm codegen)",
      "Bash(pnpm format)",
      "Bash(pnpm format:check)",
      "Bash(pnpm --filter * typecheck)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git show:*)"
    ],
    "deny": []
  }
}